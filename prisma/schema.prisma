generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Studio {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String?
  location       String?
  latitude       Float?
  longitude      Float?
  instagramUrl   String?
  facebookUrl    String?
  websiteUrl     String?
  logoUrl        String?
  phone          String?
  email          String?
  status         String      @default("live") // live, pending, rejected
  scrapeMethod   String      @default("manual") // manual, scraper
  lastVerifiedAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  classes        YogaClass[]
  suggestions    Suggestion[]
}

model YogaClass {
  id              String   @id @default(cuid())
  studioId        String
  studio          Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  title           String
  style           String
  instructor      String?
  dayOfWeek       Int      // 0=Sunday .. 6=Saturday
  startTime       String   // "09:00"
  endTime         String?  // "10:30"
  durationMin     Int?
  priceTHB        Float?
  dropInPriceTHB  Float?
  locationDetail  String?
  sourceUrl       String?
  rawText         String?
  source          String   @default("manual") // manual, scraped, community
  status          String   @default("live") // live, draft, pending_review
  isActive        Boolean  @default(true)
  lastScrapedAt   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studioId])
  @@index([dayOfWeek])
  @@index([style])
  @@index([status])
}

model Suggestion {
  id               String   @id @default(cuid())
  type             String   // correction, new_studio, new_class
  targetStudioId   String?
  targetStudio     Studio?  @relation(fields: [targetStudioId], references: [id])
  targetClassId    String?
  data             String   // JSON blob with suggestion details
  submitterContact String?
  status           String   @default("pending") // pending, approved, rejected
  adminNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([type])
}
